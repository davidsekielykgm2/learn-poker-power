{
  // Configuración básica de ESLint
  "eslint.useFlatConfig": false,  // Usamos la configuración tradicional (.eslintrc.js)
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  // Configuración del formateo
  "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },

  // Configuraciones específicas para TypeScript
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifier": "relative",

  // Configuraciones específicas para React Native
  "files.associations": {
    "*.tsx": "typescriptreact"
  },

  // Configuraciones adicionales útiles
  "editor.tabSize": 2,
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true
}