{
  // Configuración base de ESLint
  "eslint.useFlatConfig": false,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  // Configuración del formateo
  "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },

  // Configuración específica para el monorepo
  "eslint.workingDirectories": [
    {
      "pattern": "./packages/*/"
    }
  ],

  // Configuraciones de TypeScript que mantenemos de tu configuración original
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifier": "relative",

  // Configuraciones de React Native
  "files.associations": {
    "*.tsx": "typescriptreact"
  },

  // Configuraciones de estilo y formato que mantenemos
  "editor.tabSize": 2,
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  // Nuevo: Debug de ESLint para ayudar en la configuración del monorepo
  "eslint.debug": true
}